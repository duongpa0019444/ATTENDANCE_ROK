generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum Status {
  ACTIVE
  INACTIVE
}

model User {
  id                 String             @id @default(uuid())
  username           String             @unique
  password           String
  full_name          String
  telegram_id        String?            @unique
  telegram_username  String?
  telegram_linked_at DateTime?
  zalo_id            String?
  role               Role               @default(STAFF)
  status             Status             @default(ACTIVE)
  created_at         DateTime           @default(now())
  shift_assignments  ShiftAssignment[]
  attendance_logs    AttendanceLog[]
  notifications      Notification[]
  audit_logs         AuditLog[]

  @@map("users")
}

model TelegramLinkToken {
  id         String   @id @default(uuid())
  username   String
  token      String   @unique
  used       Boolean  @default(false)
  created_at DateTime @default(now())
  expired_at DateTime

  @@map("telegram_link_tokens")
}

model Server {
  id            String             @id @default(uuid())
  name          String             @unique
  status        String             @default("ACTIVE")
  base_salary   Float              @default(0)
  created_at    DateTime           @default(now())
  shifts        Shift[]
  week_salaries ServerWeekSalary[]

  @@map("servers")
}

model Shift {
  id              String            @id @default(uuid())
  server_id       String
  name            String?
  start_time      String            // e.g. "08:00"
  end_time        String            // e.g. "17:00"
  grace_minutes   Int               @default(5)
  base_salary     Float?
  bonus_salary    Float             @default(0)
  created_at      DateTime          @default(now())
  
  week_start_date DateTime?         @db.Date
  
  server          Server            @relation(fields: [server_id], references: [id], onDelete: Cascade)
  assignments     ShiftAssignment[]
  day_bonuses     ShiftDayBonus[]

  @@map("shifts")
}

model ShiftAssignment {
  id               String             @id @default(uuid())
  user_id          String
  shift_id         String
  work_date        DateTime           @db.Date
  status           String             @default("SCHEDULED")
  
  user             User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  shift            Shift              @relation(fields: [shift_id], references: [id], onDelete: Cascade)
  attendance_logs  AttendanceLog[]

  @@unique([shift_id, work_date, user_id])
  @@map("shift_assignments")
}

model AttendanceLog {
  id                  String           @id @default(uuid())
  user_id             String
  shift_assignment_id String
  confirm_at          DateTime?
  status              String           @default("PENDING") // PENDING, READY, ABSENT
  user                User             @relation(fields: [user_id], references: [id])
  shift_assignment    ShiftAssignment  @relation(fields: [shift_assignment_id], references: [id])
  escalation_logs     EscalationLog[]

  @@map("attendance_logs")
}

model Notification {
  id               String             @id @default(uuid())
  user_id          String
  channel          String             // TELEGRAM, ZALO, SYSTEM
  type             String             // REMINDER, ESCALATION, WARNING
  payload          Json               // JSONB data
  status           String             @default("PENDING") // PENDING, SENT, FAILED
  sent_at          DateTime?
  read_at          DateTime?
  user             User               @relation(fields: [user_id], references: [id])

  @@map("notifications")
}

model EscalationLog {
  id               String             @id @default(uuid())
  attendance_id    String
  level            Int                @default(1)
  triggered_at     DateTime           @default(now())
  resolved_at      DateTime?
  attendance       AttendanceLog      @relation(fields: [attendance_id], references: [id])

  @@map("escalation_logs")
}

model AuditLog {
  id               String             @id @default(uuid())
  actor_id         String?
  action           String
  entity_type      String
  entity_id        String
  metadata         Json?
  created_at       DateTime           @default(now())
  actor            User?              @relation(fields: [actor_id], references: [id])

  @@map("audit_logs")
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

model LockedPeriod {
  id         String          @id @default(uuid())
  start_date DateTime        @db.Date
  end_date   DateTime        @db.Date
  created_at DateTime        @default(now())
  payrolls   LockedPayroll[]

  @@unique([start_date, end_date])
  @@map("locked_periods")
}

model LockedPayroll {
  id                  String       @id @default(uuid())
  locked_period_id    String
  user_id             String
  username            String
  full_name           String
  role                String
  total_shifts        Int
  completed_shifts    Int
  absent_shifts       Int
  total_base_salary   Float
  total_night_bonus   Float
  total_weekend_bonus  Float
  total_other_allowance Float @default(0)
  total_shift_reward   Float
  total_salary        Float
  details             Json

  locked_period       LockedPeriod @relation(fields: [locked_period_id], references: [id], onDelete: Cascade)

  @@unique([locked_period_id, user_id])
  @@map("locked_payrolls")
}

model PayrollAllowance {
  id         String   @id @default(uuid())
  work_date DateTime @unique @db.Date
  amount    Float    @default(0)
  note      String?
  created_at DateTime @default(now())

  @@map("payroll_allowances")
}

model ShiftDayBonus {
  id         String   @id @default(uuid())
  shift_id   String
  work_date  DateTime @db.Date
  amount     Float    @default(0)
  created_at DateTime @default(now())

  shift      Shift    @relation(fields: [shift_id], references: [id], onDelete: Cascade)

  @@unique([shift_id, work_date])
  @@map("shift_day_bonuses")
}

model ServerWeekSalary {
  id          String   @id @default(uuid())
  server_id   String
  start_date  DateTime @db.Date
  end_date    DateTime @db.Date
  base_salary Float    @default(0)
  created_at  DateTime @default(now())

  server      Server   @relation(fields: [server_id], references: [id], onDelete: Cascade)

  @@unique([server_id, start_date, end_date])
  @@map("server_week_salaries")
}

